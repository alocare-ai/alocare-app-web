{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "regions": ["sin1"],
  "functions": {
    "app/api/ai/analyze/stream/route.ts": {
      "maxDuration": 300
    },
    "app/api/reports/[id]/ocr/stream/route.ts": {
      "maxDuration": 300
    },
    "app/api/reports/[id]/clinical-intelligence/stream/route.ts": {
      "maxDuration": 300
    }
  },
  "git": {
    "deploymentEnabled": false
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}

    "vercel:deploy": "vercel --prod"
  },
  "dependencies": {
    "@alocare/design-system": "file:vendor/alocare-design-system",
    "@tanstack/react-query": "^5.100.14",
    "axios": "^1.16.1",
    "lucide-react": "^0.511.0",
    "next": "15.5.18",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chalk": "^4.1.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }

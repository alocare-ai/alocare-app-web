{
  "name": "alocare-app-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "login": "./scripts/gcloud-login.sh --login",
    "login:setup": "./scripts/gcloud-login.sh",
    "generate-env": "node scripts/generate-env.cjs",
    "seed-secrets": "node scripts/seed-secrets.cjs",
    "seed-github-config": "bash scripts/seed-github-config.sh",
    "setup-git": "node scripts/setup-git.cjs",
    "postinstall": "node scripts/setup-git.cjs",
    "sync-design-system": "node scripts/sync-design-system-vendor.cjs",
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "setup:env": "npm run generate-env",
    "setup": "npm run generate-env && npm run setup-git",
    "vercel:link": "vercel link",

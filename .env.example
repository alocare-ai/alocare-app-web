# Browser-facing API URL (also used on Vercel when API_PROXY_URL is unset)
# Local stack:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8080
# Production (Vercel → app.alocare.net) — must be the API host, not the portal:
NEXT_PUBLIC_API_URL=https://api.alocare.net

# Server-side BFF routes (/api/auth/*, /api/backend/*) — optional on Vercel
# API_PROXY_URL=https://api.alocare.net
# API_REWRITE_URL=http://127.0.0.1:8080  # optional; /v1/* rewrites (dev defaults to :8080)

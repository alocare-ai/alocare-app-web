# GCP Configuration (npm run login → npm run seed-secrets → npm run generate-env)
GOOGLE_CLOUD_PROJECT_ID=personal-suherman
GOOGLE_CLOUD_QUOTA_PROJECT=personal-suherman
# Optional: pin Google account for gcloud CLI
# GCLOUD_ACCOUNT_EMAIL=you@alocare.net

# Optional: long-lived local dev SA (downloaded from Secret Manager by npm run login)
# LOCAL_DEV_GCP_SA_ID=alocare-app-web-local
# LOCAL_DEV_GCP_SA_SECRET_NAME=alocare-app-web-local-dev-sa-key
# LOCAL_DEV_GCP_SA_KEY_PATH=.credentials/keys/alocare-app-web-local.json

# Browser-facing API URL (also used on Vercel when API_PROXY_URL is unset)
# Local stack:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8080
# Production (Vercel → app.alocare.net) — must be the API host, not the portal:
NEXT_PUBLIC_API_URL=https://api.alocare.net

# Server-side BFF routes (/api/auth/*, /api/backend/*) — optional on Vercel
API_PROXY_URL=https://api.alocare.net
# API_REWRITE_URL=http://127.0.0.1:8080  # optional; /v1/* rewrites (dev defaults to :8080)

# Portal base URL (OAuth redirect URIs, email links)
# Local: http://localhost:3000
# Production: https://app.alocare.net
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Portal Google OAuth — separate OAuth client from admin console (alocare-admin-app).
# Upload to Secret Manager: npm run seed-secrets
# Upload to GitHub Actions: npm run seed-github-config
# Google Cloud Console → Credentials → OAuth 2.0 Client (Web application):
#   Authorized JavaScript origins:
#     http://localhost:3000
#     http://127.0.0.1:3000
#     https://app.alocare.net
#   Authorized redirect URIs:
#     http://localhost:3000/api/auth/callback/google
#     http://127.0.0.1:3000/api/auth/callback/google
#     https://app.alocare.net/api/auth/callback/google
PORTAL_GOOGLE_CLIENT_ID=
PORTAL_GOOGLE_CLIENT_SECRET=
